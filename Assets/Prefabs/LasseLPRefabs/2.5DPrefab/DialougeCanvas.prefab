  noButtonLabel: {fileID: 1403107203971624273}
  defaultYesLabel: Yes
  defaultNoLabel: No
  charsPerSecond: 40
  holdToFastTypeMultiplier: 3
  introText: 'In the midst of a heavy smell of milde, In the corner of your eyes,
    you spot a mysterious red liquid on the floor... '
  nodes:
  - question: Do you want to investigate?
    yesReply: 'Dhampir: I might as well have a look


      *Upon further inspection,
      you realise this could possibly be blood... this could be the first time in
      year you''ve  felt the sweet inrony taste on your tounge* '
    noReply: 'Dhampir: this place smells absolutly horrid


      *As disgusted as
      you are, you navigate towards the mysterious luquid... upon further inspection,
      you realise this could possibly be blood... this could be the first time in
      year you''ve  felt the sweet inrony taste on your tounge*'
    nextAfterYes: 1
    nextAfterNo: 1
    yesLabel: Intriuged
    noLabel: disgusted
    minutesOnEnter: 0
    minutesOnYes: 5
    minutesOnNo: 0
    mcOnYes: 0
    mcOnNo: 0
    enemyOnYes: 0
    enemyOnNo: 0
    affectsAlignment: 0
    humansOnYes: 0
    undeadOnYes: 0
    humansOnNo: 0
    undeadOnNo: 0
  - question: Do you wanna risk your humanity for the possible taste of blood?
    yesReply: "Dhampir: arhh what the hell\n\n*you reach for the substance with your
      bare fingers, exicitment fills your heart... this could be it... your finger
      almost reaces your mouth...\" \n\nRookie: Thats disgusting... leech... "
    noReply: 'Dhampir: No i really shouldn''t, im not here to feast im here to figure
      out whats going on! '
    nextAfterYes: 2
    nextAfterNo: 2
    yesLabel: 
    noLabel: 
    minutesOnEnter: 0
    minutesOnYes: 10
    minutesOnNo: 10
    mcOnYes: 0
    mcOnNo: 0
    enemyOnYes: 1
    enemyOnNo: 0
    affectsAlignment: 1
    humansOnYes: 0
    undeadOnYes: 10
    humansOnNo: 10
    undeadOnNo: 0
  - question: 'As you trying to get back up, with the upward motion of your head,
      you spot an empty bottle of wine... could this be a pontential clue? '
    yesReply: ' '
    noReply: "\n "
