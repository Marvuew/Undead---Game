  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MessageChainDialogue
  autoStartOnPlay: 0
  conversationId: cellar_intro
  rememberCompletion: 1
  revisitText: We've already been here, maybe we should look at some other place?
  dialoguePanel: {fileID: 990607893904239515}
