  m_Script: {fileID: 11500000, guid: c67b29872dec946adae8515647564702, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MessageChainDialogue
  autoStartOnPlay: 0
  conversationId: cellar_intro
  rememberCompletion: 1
  revisitText: We've already been here, maybe we should look at some other place?
  dialoguePanel: {fileID: 650380243231355292}
  scrollRect: {fileID: 4998041816115045693}
  transcriptText: {fileID: 7597449785863321597}
  choicesPanel: {fileID: 6794812792418878698}
  yesButton: {fileID: 7528115821795169337}
  noButton: {fileID: 4770295495552513178}
  charsPerSecond: 40
  holdToFastTypeMultiplier: 3
  introText: 'You enter a dimly lit area, you notice the smell of rot and  moistier
    in the air, i feels disgusting. In the corner of your eyes you spot a mysterious
    red liquid on the floor... '
  nodes:
  - question: Do you want to investigate?
    yesReply: 'You kneel down to get a closer look, but its almost like you cant
      fully figure out what it is by looks. the longer you look at it the more the
      mysterious liquid is reminding you of blood. The only way to know for what
      this substance is is to taste it '
    noReply: 'This room smells horrible, ill come back later. i need to get some
      fresh air for now. '
    nextAfterYes: 1
    nextAfterNo: -1
    affectsAlignment: 0
    humansOnYes: 0
    undeadOnYes: 0
    humansOnNo: 0
    undeadOnNo: 0
  - question: Do you want to investigate and risk the temptation of tasting the sweetnes
      of blood, or do you turn turn it away.
    yesReply: '*you take your finger and exitingly run it trough the liquid, but
      as it your fingerstouches your lips you feel a dissaproving stare from the
      rookie behind you* "thats disgusting man". -5 human '
    noReply: "\"No i cant risk it its probably better that i dont\"\n "
    nextAfterYes: 2
    nextAfterNo: 2
    affectsAlignment: 1
    humansOnYes: 0
    undeadOnYes: 10
    humansOnNo: 10
    undeadOnNo: 0
  - question: you spot an empty bottle of wine, that you pick up, could this be a
      clue?
    yesReply: ' '
    noReply: "\n "
    nextAfterYes: -1
    nextAfterNo: -1
    affectsAlignment: 0
    humansOnYes: 0
    undeadOnYes: 0
    humansOnNo: 0
    undeadOnNo: 0
  readDelaySeconds: 10
  skipDelayKey: 1
  clearTranscriptOnStart: 1
  autoScrollToBottom: 1
  endPromptText: Where should we go next?
  cluePopup: {fileID: 6440372328058881003}
