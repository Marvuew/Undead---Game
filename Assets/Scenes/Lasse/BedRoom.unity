    - target: {fileID: 8884357301928637071, guid: 00095f5ef19554217ae6d5a81fd425c7, type: 3}
      propertyPath: nodes.Array.data[0].noLabel
      value: smell it
      objectReference: {fileID: 0}
    - target: {fileID: 8884357301928637071, guid: 00095f5ef19554217ae6d5a81fd425c7, type: 3}
      propertyPath: nodes.Array.data[0].noReply
      value: 'You bow down to smell it, and as you do a particle of this powder flies
        up into your nose.  you can feel it in your system, and the paranoia raises...
        but nothing more happens. you realise this is probably the work of some creatures
        from your book. '
      objectReference: {fileID: 0}
    - target: {fileID: 8884357301928637071, guid: 00095f5ef19554217ae6d5a81fd425c7, type: 3}
      propertyPath: nodes.Array.data[1].noLabel
